<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <Switch
        android:id="@+id/switchMic"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/use_mic_mode"
        android:textSize="14sp"
        android:checked="false" />

    <!-- 识别模式 -->
    <Switch
        android:id="@+id/switchStreaming"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="流式识别（边说边出字）"
        android:textSize="14sp"
        android:checked="false"
        android:layout_marginTop="4dp" />

    <!-- 识别语言 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="识别语言"
            android:textSize="12sp" />

        <Spinner
            android:id="@+id/spinnerLanguage"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp" />

    </LinearLayout>

    <!-- 停顿间隔 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="4dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="停顿间隔"
            android:textSize="12sp" />

        <SeekBar
            android:id="@+id/seekSilence"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:max="39"
            android:progress="7" />

        <TextView
            android:id="@+id/tvSilence"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0.40s"
            android:textSize="12sp"
            android:minWidth="36dp" />

    </LinearLayout>

    <!-- 说话人区分灵敏度 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="4dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="说话人区分灵敏度"
            android:textSize="12sp" />

        <SeekBar
            android:id="@+id/seekThreshold"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:max="100"
            android:progress="40" />

        <TextView
            android:id="@+id/tvThreshold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0.40"
            android:textSize="12sp"
            android:minWidth="36dp" />

    </LinearLayout>

    <!-- 悬浮窗 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="4dp"
        android:gravity="center_vertical">

        <Switch
            android:id="@+id/switchOverlay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="悬浮窗"
            android:textSize="12sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="  透明度"
            android:textSize="12sp" />

        <SeekBar
            android:id="@+id/seekAlpha"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:max="90"
            android:progress="75" />

        <TextView
            android:id="@+id/tvAlpha"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="85%"
            android:textSize="12sp"
            android:minWidth="32dp" />

    </LinearLayout>

    <Button
        android:id="@+id/btnToggle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/start_transcription"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="就绪"
        android:textSize="12sp"
        android:textColor="@color/teal_200" />

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="12dp"
        android:background="#1A000000"
        android:padding="8dp">

        <TextView
            android:id="@+id/tvTranscription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/transcription_hint"
            android:textSize="14sp"
            android:lineSpacingExtra="4dp" />

    </ScrollView>

    <!-- 底部信息和操作 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="4dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvFilePath"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="10sp"
            android:textColor="#888888" />

        <Button
            android:id="@+id/btnNotion"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="上传Notion"
            android:textSize="11sp"
            android:minWidth="0dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp" />

    </LinearLayout>

</LinearLayout>
